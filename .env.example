# Environment Configuration Example
# Copy to `.env` in the project root. Docker Compose substitutes ${...} values
# from `.env` when you run `docker compose up`.

# Model configuration
MODEL_PATH=/app/src/yolo26n.pt

# Server configuration
LOG_LEVEL=info
API_HOST=0.0.0.0

# Docker: same port on host and in the container (uvicorn listens here too).
APP_PORT=8080

# Camera settings (optional)
DEFAULT_CAMERA_ID=0
DEFAULT_CAMERA_TIMEOUT=30

# Detection settings
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# Waste-focused detection (no extra training). Labels still come from the model
# (e.g. COCO: bottle, cup, bowl — there is no built-in "waste" class).
# WASTE_PRESET=bottles        # bottle only (strictest proxy)
# WASTE_PRESET=disposables    # bottle,cup,bowl
# WASTE_PRESET=cups           # cup,bowl
# Or explicit class names (overrides WASTE_PRESET):
# WASTE_CLASSES=bottle,cup,bowl
# Disable filter — detect all classes the model knows:
# WASTE_DETECT_ALL=1
# Legacy env names PLASTIC_WASTE_* still work if WASTE_* is unset.

# Docker Compose (optional — defaults to disposables if omitted)
WASTE_PRESET=disposables

# Performance
SKIP_FRAMES=1  # Process every Nth frame (1 = every frame, 5 = every 5th frame)
MAX_WORKERS=4

# Storage
DETECTIONS_DIR=/app/detections
SAVE_RESULTS=true
